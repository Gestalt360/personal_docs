99-Meta/keep_sync_manifest_*.json

# Ignore temp files
*.tmp
*.bak
~$*

# Keep everything else tracked
!00-Inbox/
!10-Projects/
!20-Areas/
!30-Resources/
!40-Archive/
!90-Tools/
!99-Meta/
