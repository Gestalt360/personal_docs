    "@hello-pangea/dnd": "^16.5.0",
    "@octokit/rest": "^22.0.1",
    "date-fns": "^3.0.0",
    "idb": "^8.0.3",
    "lucide-react": "^0.300.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^9.0.0",
    "react-masonry-css": "^1.0.16",
    "remark-gfm": "^4.0.0",
